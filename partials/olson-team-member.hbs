<div class="gh-team-card">
    {{#if profile_image}}
        <img class="gh-team-photo" src="{{img_url profile_image size="s" format="webp"}}" alt="{{name}}">
    {{else}}
        {{> "icons/avatar"}}
    {{/if}}
    <h3 class="gh-team-name">{{name}}</h3>
    {{#if bio}}
        <p class="gh-team-role">{{bio}}</p>
    {{/if}}
    <div class="gh-team-social">
        {{#if website}}
            <a href="{{website}}" target="_blank" rel="noopener" aria-label="Website"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg></a>
        {{/if}}
        {{#if twitter}}
            <a href="{{social_url type="twitter"}}" target="_blank" rel="noopener" aria-label="Twitter / X">{{> "icons/twitter"}}</a>
        {{/if}}
        {{#if linkedin}}
            <a href="{{social_url type="linkedin"}}" target="_blank" rel="noopener" aria-label="LinkedIn">{{> "icons/linkedin"}}</a>
        {{/if}}
        {{#if bluesky}}
            <a href="{{social_url type="bluesky"}}" target="_blank" rel="noopener" aria-label="Bluesky">{{> "icons/bluesky"}}</a>
        {{/if}}
        {{#if threads}}
            <a href="{{social_url type="threads"}}" target="_blank" rel="noopener" aria-label="Threads">{{> "icons/threads"}}</a>
        {{/if}}
        {{#if mastodon}}
            <a href="{{social_url type="mastodon"}}" target="_blank" rel="noopener" aria-label="Mastodon">{{> "icons/mastodon"}}</a>
        {{/if}}
        {{#if youtube}}
            <a href="{{social_url type="youtube"}}" target="_blank" rel="noopener" aria-label="YouTube">{{> "icons/youtube"}}</a>
        {{/if}}
    </div>
</div>
