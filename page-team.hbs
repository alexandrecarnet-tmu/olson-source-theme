{{!< default}}
{{!-- Template for a "Team" page. In Ghost Admin, create a Page and set its template to "Team". --}}

{{#post}}

<main class="gh-main">
    <article class="gh-article {{post_class}}">

        {{#match @page.show_title_and_feature_image}}
            <header class="gh-article-header gh-canvas">
                <h1 class="gh-article-title is-title">{{title}}</h1>
                {{#if custom_excerpt}}
                    <p class="gh-article-excerpt is-body">{{custom_excerpt}}</p>
                {{/if}}
                {{> "feature-image"}}
            </header>
        {{/match}}

        <section class="gh-content gh-canvas is-body">
            {{#get "authors" limit="100"}}
                <div class="gh-team-grid">
                    {{#foreach authors}}
                        {{> "olson-team-member"}}
                    {{/foreach}}
                </div>
            {{/get}}
            {{content}}
        </section>

    </article>
</main>

{{/post}}
